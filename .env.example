# ==========================================
# Anti-Byte Landing Page - Environment Variables
# ==========================================
# Copie este arquivo como .env e preencha com seus valores
cp .env.example .env

# ==========================================
# Application Environment
# ==========================================
NODE_ENV=development

# ==========================================
# Server Configuration
# ==========================================
PORT=5173
HOST=localhost

# ==========================================
# API Configuration (se houver backend)
# ==========================================
API_URL=http://localhost:3000/api
API_KEY=

# ==========================================
# Database Configuration (se houver)
# ==========================================
DATABASE_URL=
DATABASE_POOL=

# ==========================================
# Authentication (se houver)
# ==========================================
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ==========================================
# Analytics/Tracking
# ==========================================
GA_MEASUREMENT_ID=
GA_SECRET=

# ==========================================
# Third-party Services
# ==========================================
SENDGRID_API_KEY=
STRIPE_SECRET_KEY=

# ==========================================
# CORS
# ==========================================
CORS_ORIGIN=http://localhost:3000

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=debug

# ==========================================
# Feature Flags
# ==========================================
ENABLE_ANALYTICS=true
ENABLE_CACHE=true

# ==========================================
# Development Options
# ==========================================
HOT_RELOAD=true
DEBUG_MODE=true
